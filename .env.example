# Supabase — crear proyecto `naturelly` y copiar las claves desde
# Dashboard → Settings → API Keys (sistema moderno de claves)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=   # sb_publishable_... (clientes públicos, siempre bajo RLS)
SUPABASE_SECRET_KEY=                    # sb_secret_... SOLO en servidor. Nunca NEXT_PUBLIC_, nunca exponer.

# WhatsApp del negocio en formato internacional sin "+"
# TODO: confirmar con Nelly el número real
NEXT_PUBLIC_WHATSAPP_NUMBER=51XXXXXXXXX

# Deploy oficial del MVP: Render (URL provisional).
